# Server
PORT=4000

# MongoDB
# Local (without Docker): mongodb://localhost:27019
# Docker internal:        mongodb://pantry_db:27017
MONGO_URI=mongodb://localhost:27019

# Auth
JWT_SECRET=change_me

# Swagger — set to the host-accessible URL so the UI can reach the API
# Local (without Docker): leave unset, defaults to http://localhost:PORT/api
# Docker:                 set by docker-compose automatically to http://localhost:4001/api
# SWAGGER_SERVER_URL=http://localhost:4001/api
