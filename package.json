{
  "name": "pantry-chan",
  "version": "1.0.0",
  "description": "A react app, to manage pantry inventory and cooking recipes",
  "main": "index.js",
"scripts": {
  "docker:up": "docker compose up -d",
  "docker:up:dev": "docker compose -f docker-compose.dev.yml up -d",
  "docker:up:db": "docker compose -f docker-compose.db.yml up -d",
  "docker:down": "docker compose down",
  "docker:down:dev": "docker compose -f docker-compose.dev.yml down",
  "docker:down:db": "docker compose -f docker-compose.db.yml down",
  "dev": "concurrently \"npm:docker:up:db\" \"npm run dev --prefix backend\" \"npm start --prefix frontend\"",
  "start:backend": "npm run dev --prefix backend",
  "start:frontend": "npm start --prefix frontend",
  "migrate": "npm run migrate --prefix backend"
},
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
